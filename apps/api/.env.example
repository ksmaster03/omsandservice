# ─── App ───
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database ───
DATABASE_URL=postgresql://admin@localhost:5432/nba_oms_dev?schema=public

# ─── JWT ─── (generate: openssl rand -base64 48)
JWT_SECRET=replace_with_a_random_string_at_least_32_chars_long
JWT_REFRESH_SECRET=replace_with_another_random_string_at_least_32_chars_long

# ─── CORS ───
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ─── LINE (set up in Sprint 6) ───
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ─── AWS (set up in Sprint 0 infra step) ───
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_UPLOAD_BUCKET=nba-uploads

# ─── WMS (mocked until spec available) ───
WMS_BASE_URL=
