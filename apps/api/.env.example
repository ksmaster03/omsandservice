# ─── App ───
NODE_ENV=development
PORT=4100
HOST=0.0.0.0

# ─── Database ───
# Adjust host/port/user to match your local Postgres.
# If using the Homebrew postgresql@16 on 5432, or another instance on 5433.
DATABASE_URL=postgresql://nba:nba_dev_password@localhost:5432/nba_oms_dev?schema=public

# ─── JWT ─── (generate: openssl rand -base64 48)
JWT_SECRET=replace_with_a_random_string_at_least_32_chars_long
JWT_REFRESH_SECRET=replace_with_another_random_string_at_least_32_chars_long

# ─── CORS ───
CORS_ORIGINS=http://localhost:4110,http://localhost:4120,http://localhost:4130

# ─── Rate limit ─── (set MAX=0 to disable, useful for load tests)
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute

# ─── LINE (set up in Sprint 6) ───
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ─── AWS (set up in Sprint 0 infra step) ───
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_UPLOAD_BUCKET=nba-uploads

# ─── WMS (mocked until spec available) ───
WMS_BASE_URL=
WMS_API_KEY=
