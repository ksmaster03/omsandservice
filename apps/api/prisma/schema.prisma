// NBA Sport OMS — Prisma schema
// Models mirror the locked plan (18-week roadmap)
// See MEMORY.md in .claude/ for context

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH / USERS ────────────────────────────────────────────
enum UserRole {
  SALES
  INSTALL
  SERVICE
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         UserRole
  skills       String[] @default([])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedLeads       Lead[]          @relation("leadOwner")
  createdQuotes    Quotation[]     @relation("quoteCreator")
  installedJobs    Installation[]  @relation("installTech")
  ticketsAssigned  ServiceTicket[] @relation("ticketTech")
  pmsAssigned      PmSchedule[]    @relation("pmTech")
  rmasAssigned     Rma[]           @relation("rmaTech")
  location         TechLocation?
  auditLogs        AuditLog[]
  ticketEvents     TicketEvent[]
}

// ─── CUSTOMER ────────────────────────────────────────────────
enum CustomerType {
  INDIVIDUAL
  CORPORATE
}

model Customer {
  id               String       @id @default(uuid())
  wmsCode          String?      @unique
  name             String
  alternateName    String?
  taxId            String?
  type             CustomerType @default(CORPORATE)
  contactName      String?
  phone            String?
  email            String?
  address          String?
  alternateAddress String?
  lat              Decimal?     @db.Decimal(10, 7)
  lng              Decimal?     @db.Decimal(10, 7)
  active           Boolean      @default(true)
  customData       Json?        @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users       CustomerUser[]
  leads       Lead[]
  quotations  Quotation[]
  orders      SalesOrder[]
  assets      Asset[]
  tickets           ServiceTicket[]
  rmas              Rma[]
  serviceAgreements ServiceAgreement[]
}

model CustomerUser {
  id          String    @id @default(uuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lineUserId  String?   @unique
  phone       String?   @unique
  email       String?
  displayName String
  avatarUrl   String?
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())

  notifications Notification[]
  lineMessages  LineMessage[]
}

// ─── PRODUCT ─────────────────────────────────────────────────
enum Brand {
  MAXNUM
  GORILLA_TECK
  ANYFIT
  IMPULSE
}

model Product {
  id               String   @id @default(uuid())
  sku              String   @unique
  wmsPartNo        String?  @unique
  brand            Brand
  name             String
  category         String
  partType         String?
  uom              String   @default("EA")
  standardPack     Int?
  price            Decimal  @db.Decimal(12, 2)
  warrantyMonths   Int      @default(24)
  pmIntervalMonths Int      @default(3)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  quoteItems QuotationItem[]
  soItems    SOItem[]
  demos      Demo[]
  assets     Asset[]
  stockItem  StockItem?
}

// ─── STOCK + RESERVATION ─────────────────────────────────────
// Single-warehouse model for now. `onHand` is authoritative physical
// inventory; `reserved` is the sum of ACTIVE reservations against it.
// Available = onHand - reserved. Reserve at SO confirm, release on
// cancel, consume (decrement onHand) when Installation completes.
model StockItem {
  id        String   @id @default(uuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  onHand    Int      @default(0)
  reserved  Int      @default(0)
  reorderAt Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  reservations StockReservation[]

  @@index([productId])
}

enum StockReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
}

// ─── RMA / RETURNS ───────────────────────────────────────────
// Handles post-sale returns: the customer or sales rep raises a
// return request against an Asset; ops approves/rejects; tech picks
// up the machine; QC inspects; resolution = refund, replacement, or
// refurbish-and-return. State machine lives in shared/machines.
enum RmaStage {
  REQUESTED
  APPROVED
  REJECTED
  PICKUP_SCHEDULED
  PICKED_UP
  INSPECTING
  REFUNDED
  REPLACED
  REFURBISHED
  CANCELLED
}

enum RmaReason {
  DOA            // dead on arrival
  DEFECT
  WRONG_ITEM
  CUSTOMER_CHANGE_MIND
  WARRANTY_CLAIM
  OTHER
}

enum RmaResolution {
  REFUND
  REPLACE
  REFURBISH
  REJECTED
}

model Rma {
  id              String         @id @default(uuid())
  rmaNo           String         @unique
  businessKey     String?        @unique
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id])
  assetId         String
  asset           Asset          @relation(fields: [assetId], references: [id])
  soId            String?
  reason          RmaReason
  description     String
  stage           RmaStage       @default(REQUESTED)
  resolution      RmaResolution?
  pickupAt        DateTime?
  pickedUpAt      DateTime?
  inspectedAt     DateTime?
  closedAt        DateTime?
  refundAmount    Decimal?       @db.Decimal(12, 2)
  replacementAssetId String?
  techId          String?
  tech            User?          @relation("rmaTech", fields: [techId], references: [id])
  note            String?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  events          RmaEvent[]

  @@index([customerId])
  @@index([assetId])
  @@index([stage])
}

model RmaEvent {
  id        String   @id @default(uuid())
  rmaId     String
  rma       Rma      @relation(fields: [rmaId], references: [id], onDelete: Cascade)
  stage     RmaStage
  note      String?
  actorId   String?
  createdAt DateTime @default(now())

  @@index([rmaId])
}

model StockReservation {
  id          String                 @id @default(uuid())
  stockItemId String
  stockItem   StockItem              @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  productId   String
  soId        String
  soItemId    String
  qty         Int
  status      StockReservationStatus @default(ACTIVE)
  expiresAt   DateTime?
  createdAt   DateTime               @default(now())
  releasedAt  DateTime?
  consumedAt  DateTime?
  note        String?

  @@index([soId])
  @@index([productId])
  @@index([status])
}

// ─── SALES PIPELINE ──────────────────────────────────────────
enum LeadStage {
  LEAD
  QUALIFIED
  DEMO
  QUOTE
  NEGOTIATION
  WON
  LOST
}

model Lead {
  id            String     @id @default(uuid())
  customerId    String
  ownerId       String
  stage         LeadStage  @default(LEAD)
  value         Decimal    @db.Decimal(12, 2)
  expectedClose DateTime?
  note          String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  customer   Customer    @relation(fields: [customerId], references: [id])
  owner      User        @relation("leadOwner", fields: [ownerId], references: [id])
  quotations Quotation[]
  demos      Demo[]
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quotation {
  id         String      @id @default(uuid())
  quoteNo    String      @unique
  leadId     String?
  customerId String
  salesId    String
  status     QuoteStatus @default(DRAFT)
  subtotal   Decimal     @db.Decimal(12, 2)
  discount   Decimal     @default(0) @db.Decimal(12, 2)
  vat        Decimal     @db.Decimal(12, 2)
  total      Decimal     @db.Decimal(12, 2)
  validUntil DateTime
  pdfS3Key   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  lead     Lead?           @relation(fields: [leadId], references: [id])
  customer Customer        @relation(fields: [customerId], references: [id])
  sales    User            @relation("quoteCreator", fields: [salesId], references: [id])
  items    QuotationItem[]
  order    SalesOrder?
}

model QuotationItem {
  id          String  @id @default(uuid())
  quotationId String
  productId   String
  qty         Int
  unitPrice   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
}

// ─── ORDER / FULFILLMENT ─────────────────────────────────────
enum SOStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY_TO_DELIVER
  INSTALLED
  COMPLETED
  CANCELLED
}

model SalesOrder {
  id          String   @id @default(uuid())
  soNo        String   @unique
  businessKey String?  @unique
  quotationId String?  @unique
  customerId  String
  status      SOStatus @default(PENDING)
  total       Decimal  @db.Decimal(12, 2)
  wmsOrderId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotation    Quotation?         @relation(fields: [quotationId], references: [id])
  customer     Customer           @relation(fields: [customerId], references: [id])
  items        SOItem[]
  milestones   PaymentMilestone[]
  installation Installation?
  assets       Asset[]
}

model SOItem {
  id        String  @id @default(uuid())
  soId      String
  productId String
  qty       Int
  unitPrice Decimal @db.Decimal(12, 2)

  so      SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id])
}

enum MilestoneStatus {
  PENDING
  DUE
  PAID
  OVERDUE
}

model PaymentMilestone {
  id      String          @id @default(uuid())
  soId    String
  seq     Int
  label   String
  amount  Decimal         @db.Decimal(12, 2)
  dueDate DateTime
  paidAt  DateTime?
  status  MilestoneStatus @default(PENDING)

  so SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
}

// ─── DEMO / INSTALL ──────────────────────────────────────────
enum DemoStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Demo {
  id           String     @id @default(uuid())
  leadId       String
  productId    String
  scheduledAt  DateTime
  status       DemoStatus @default(SCHEDULED)
  note         String?
  location     String?
  address      String?
  contactName  String?
  contactPhone String?
  createdAt    DateTime   @default(now())

  lead    Lead    @relation(fields: [leadId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

enum InstallStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Installation {
  id          String        @id @default(uuid())
  businessKey String?       @unique
  soId        String        @unique
  scheduledAt DateTime
  techId      String?
  status      InstallStatus @default(SCHEDULED)
  completedAt DateTime?
  photos      String[]      @default([])
  note        String?

  so   SalesOrder @relation(fields: [soId], references: [id])
  tech User?      @relation("installTech", fields: [techId], references: [id])
}

// ─── ASSET + WARRANTY + PM ───────────────────────────────────
model Asset {
  id             String    @id @default(uuid())
  serialNo       String    @unique
  productId      String
  customerId     String
  soId           String
  installedAt    DateTime
  warrantyEnd    DateTime
  nextPmDate     DateTime?
  locationDetail String?

  product  Product           @relation(fields: [productId], references: [id])
  customer Customer          @relation(fields: [customerId], references: [id])
  so       SalesOrder        @relation(fields: [soId], references: [id])
  pmSchedules PmSchedule[]
  tickets     ServiceTicket[]
  renewals    WarrantyRenewal[]
  rmas        Rma[]
}

enum PmStatus {
  PENDING
  SCHEDULED
  COMPLETED
  OVERDUE
  SKIPPED
}

model PmSchedule {
  id          String    @id @default(uuid())
  assetId     String
  scheduledAt DateTime
  techId      String?
  status      PmStatus  @default(PENDING)
  completedAt DateTime?
  note        String?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tech  User? @relation("pmTech", fields: [techId], references: [id])
}

enum RenewalStatus {
  OFFERED
  ACCEPTED
  PAID
  EXPIRED
}

model WarrantyRenewal {
  id         String        @id @default(uuid())
  assetId    String
  type       String
  price      Decimal       @db.Decimal(12, 2)
  status     RenewalStatus @default(OFFERED)
  newEndDate DateTime?
  paidAt     DateTime?
  createdAt  DateTime      @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// ─── SERVICE TICKET ──────────────────────────────────────────
enum ProblemType {
  BELT
  NOISE
  CONSOLE
  MOTOR
  POWER
  PM
  OTHER
}

enum Priority {
  URGENT
  NORMAL
  LOW
}

enum TicketStage {
  RECEIVED
  ASSIGNED
  EN_ROUTE
  ARRIVED
  REPAIRING
  CLOSED
  CANCELLED
}

model ServiceTicket {
  id              String      @id @default(uuid())
  ticketNo        String      @unique
  businessKey     String?     @unique
  customerId      String
  assetId         String
  problemType     ProblemType
  priority        Priority
  description     String
  locationLat     Decimal?    @db.Decimal(10, 7)
  locationLng     Decimal?    @db.Decimal(10, 7)
  locationAddress String?
  locationDetail  String?
  assignedTechId  String?
  stage           TicketStage @default(RECEIVED)
  slaDueAt        DateTime?
  closedAt        DateTime?
  customerRating  Int?
  customerReview  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customer Customer      @relation(fields: [customerId], references: [id])
  asset    Asset         @relation(fields: [assetId], references: [id])
  tech     User?         @relation("ticketTech", fields: [assignedTechId], references: [id])
  photos   TicketPhoto[]
  video    TicketVideo?
  events   TicketEvent[]
}

model TicketPhoto {
  id       String @id @default(uuid())
  ticketId String
  s3Key    String
  size     Int

  ticket ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model TicketVideo {
  id       String @id @default(uuid())
  ticketId String @unique
  s3Key    String
  size     Int
  duration Int?

  ticket ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model TicketEvent {
  id        String      @id @default(uuid())
  ticketId  String
  stage     TicketStage
  note      String?
  actorId   String?
  createdAt DateTime    @default(now())

  ticket ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User?         @relation(fields: [actorId], references: [id])
}

// ─── LIVE GPS TRACKING ───────────────────────────────────────
model TechLocation {
  techId         String   @id
  lat            Decimal  @db.Decimal(10, 7)
  lng            Decimal  @db.Decimal(10, 7)
  accuracy       Float?
  activeTicketId String?
  updatedAt      DateTime @updatedAt

  tech User @relation(fields: [techId], references: [id], onDelete: Cascade)
}

// ─── WMS SYNC ────────────────────────────────────────────────
enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
  RETRY
}

model WmsStockCache {
  sku       String
  warehouse String
  qty       Int
  updatedAt DateTime @updatedAt

  @@id([sku, warehouse])
}

model WmsSyncLog {
  id           String     @id @default(uuid())
  entity       String
  action       String
  requestJson  Json
  responseJson Json?
  status       SyncStatus @default(PENDING)
  errorMsg     String?
  createdAt    DateTime   @default(now())
}

// ─── LINE INTEGRATION ────────────────────────────────────────
enum MsgDir {
  IN
  OUT
}

model LineMessage {
  id             String   @id @default(uuid())
  customerUserId String?
  ticketId       String?
  direction      MsgDir
  text           String?
  imageS3Key     String?
  lineMessageId  String?
  createdAt      DateTime @default(now())

  customerUser CustomerUser? @relation(fields: [customerUserId], references: [id])
}

// ─── SERVICE AGREEMENT (Recurring contracts) ────────────────
enum ServiceAgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELLED
}

model ServiceAgreement {
  id           String                 @id @default(uuid())
  agreementNo  String                 @unique
  customerId   String
  customer     Customer               @relation(fields: [customerId], references: [id])
  type         String                 @default("PM_PACKAGE")
  coverage     String?
  startDate    DateTime
  endDate      DateTime
  price        Decimal                @db.Decimal(12, 2)
  status       ServiceAgreementStatus @default(DRAFT)
  autoRenew    Boolean                @default(false)
  note         String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([endDate])
}

// ─── SPARE PARTS ─────────────────────────────────────────────
model SparePart {
  id          String   @id @default(uuid())
  partNo      String   @unique
  name        String
  category    String?
  unit        String   @default("EA")
  costPrice   Decimal? @db.Decimal(12, 2)
  sellPrice   Decimal? @db.Decimal(12, 2)
  onHand      Int      @default(0)
  reorderAt   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usages      SparePartUsage[]

  @@index([partNo])
}

model SparePartUsage {
  id          String   @id @default(uuid())
  sparePartId String
  sparePart   SparePart @relation(fields: [sparePartId], references: [id])
  ticketId    String?
  rmaId       String?
  pmId        String?
  qty         Int
  techId      String?
  note        String?
  createdAt   DateTime @default(now())

  @@index([sparePartId])
  @@index([ticketId])
}

// ─── INSTALLATION CHECKLIST ──────────────────────────────────
model InstallChecklist {
  id              String   @id @default(uuid())
  installationId  String
  step            Int
  label           String
  checked         Boolean  @default(false)
  photoKey        String?
  note            String?
  checkedAt       DateTime?
  checkedBy       String?

  @@index([installationId])
}

// ─── FEEDBACK ────────────────────────────────────────────────
enum FeedbackType {
  BUG
  FEATURE
  IMPROVEMENT
  QUESTION
  OTHER
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  WONT_FIX
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Feedback {
  id          String           @id @default(uuid())
  type        FeedbackType
  priority    FeedbackPriority @default(MEDIUM)
  status      FeedbackStatus   @default(OPEN)
  subject     String
  description String
  screenshot  String?
  attachments Json?
  source      String           @default("admin")
  submittedBy String?
  submitterName String?
  submitterEmail String?
  assignedTo  String?
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  replies     FeedbackReply[]

  @@index([status])
  @@index([type])
}

model FeedbackReply {
  id         String   @id @default(uuid())
  feedbackId String
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  message    String
  authorName String
  authorRole String?
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([feedbackId])
}

// ─── SETTINGS / SYSTEM ───────────────────────────────────────
model Setting {
  key       String   @id
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model Notification {
  id             String    @id @default(uuid())
  customerUserId String?
  userId         String?
  type           String
  title          String
  body           String
  link           String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  customerUser CustomerUser? @relation(fields: [customerUserId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  entity    String
  entityId  String
  action    String
  diff      Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
