{
  "Serilog": {
    "MinimumLevel": "Information"
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "dotnet-ping": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/ping" } },
      "dotnet-ready": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/ready" } },
      "dotnet-auth": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/auth/{**rest}" } },
      "dotnet-customer-auth": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/customer/auth/{**rest}" } },
      "dotnet-customer-portal": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/customer/{**rest}" } },
      "dotnet-tech": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/tech/{**rest}" } },
      "dotnet-feedback": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/feedback/{**rest}" } },
      "dotnet-customers": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/customers/{**rest}" } },
      "dotnet-products": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/products/{**rest}" } },
      "dotnet-users": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/users/{**rest}" } },
      "dotnet-leads": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/leads/{**rest}" } },
      "dotnet-quotations": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/quotations/{**rest}" } },
      "dotnet-sales-orders": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/sales-orders/{**rest}" } },
      "dotnet-tickets": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/tickets/{**rest}" } },
      "dotnet-assets": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/assets/{**rest}" } },
      "dotnet-pm-schedules": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/pm-schedules/{**rest}" } },
      "dotnet-rmas": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/rmas/{**rest}" } },
      "dotnet-renewals": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/renewals/{**rest}" } },
      "dotnet-service-agreements": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/service-agreements/{**rest}" } },
      "dotnet-reports": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/reports/{**rest}" } },
      "dotnet-stock": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/stock/{**rest}" } },
      "dotnet-wms": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/api/v1/internal/wms/{**rest}" } },
      "dotnet-tech-hub": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/hubs/tech/{**rest}" } },
      "dotnet-swagger": { "ClusterId": "dotnet-cluster", "Match": { "Path": "/swagger/{**rest}" } },
      "node-fallback": { "ClusterId": "node-cluster", "Match": { "Path": "/{**catch-all}" } }
    },
    "Clusters": {
      "dotnet-cluster": {
        "Destinations": {
          "primary": { "Address": "http://api-dotnet:4111/" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "node-cluster": {
        "Destinations": {
          "primary": { "Address": "http://api-node:4100/" }
        }
      }
    }
  }
}
