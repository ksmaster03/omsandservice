{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=oms_dev;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "td-oms-service",
    "Audience": "td-oms-clients",
    "Secret": "REPLACE_WITH_AT_LEAST_32_CHAR_SECRET_FROM_USER_SECRETS_OR_KEYVAULT",
    "ExpiryMinutes": 480,
    "OtpTtlSeconds": 300
  },
  "Cors": {
    "Origins": "http://localhost:4101,http://localhost:4102,http://localhost:4103"
  },
  "RateLimit": {
    "EnableEndpointRateLimiting": true,
    "GeneralRules": [
      { "Endpoint": "*", "Period": "1m", "Limit": 300 }
    ]
  },
  "Storage": {
    "UploadRoot": "uploads",
    "MaxImageBytes": 10485760,
    "MaxVideoBytes": 52428800,
    "MaxFeedbackBytes": 5242880
  }
}
